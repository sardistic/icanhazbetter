{
  "manifest_version": 3,
  "name": "icanhazbetter",
  "version": "1.1",
  "description": "Dark theme, flexible room layout, cam management, and chat improvements for icanhazchat.com",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://images.icanhazchat.com/*",
    "https://www.icanhazchat.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["gifs.txt"],
      "matches": ["https://www.icanhazchat.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.icanhazchat.com/*"],
      "css": [
        "styles/theme.css",
        "styles/pm.css"
      ],
      "js": [
        "scripts/persist-hidecams.js",
        "scripts/theme.js",
        "scripts/chat.js",
        "scripts/pm.js",
        "scripts/modernize.js"
      ],
      "run_at": "document_start"
    }
  ]
}
